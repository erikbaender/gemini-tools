{
  "manifest_version": 3,
  "name": "Gemini Tools",
  "version": "0.1.0",
  "description": "Allows you to customize the Gemini web app beyond the limited settings exposed to the user.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/options.html",
    "default_title": "Gemini Tools",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://*.gemini.google.com/*"
      ],
      "js": [
        "src/lib/safety-guards.js",
        "src/lib/retry-handler.js",
        "src/lib/selector-strategy.js",
        "src/lib/model-setter.js",
        "src/lib/notification.js",
        "src/lib/upgrade-guard.js",
        "src/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
